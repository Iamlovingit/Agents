#!/usr/bin/env bash
set -euo pipefail

case "${HERMES_AUTOSTART:-true}" in
    0|false|FALSE|no|NO|off|OFF)
        exit 0
        ;;
esac

if command -v flock >/dev/null 2>&1; then
    exec 9>/tmp/hermes-terminal-autostart.lock
    flock -n 9 || exit 0
fi

export HOME="${HOME:-/config}"
export HERMES_HOME="${HERMES_HOME:-/config/.hermes}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-/config/.cache}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-/config/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-/config/.local/share}"
export NPM_CONFIG_CACHE="${NPM_CONFIG_CACHE:-/config/.cache/npm}"
export UV_CACHE_DIR="${UV_CACHE_DIR:-/config/.cache/uv}"

/usr/local/bin/hermes-apply-runtime-config >/tmp/hermes-runtime-config.log 2>&1 || true

mkdir -p "${HOME}" "${XDG_CACHE_HOME}" "${XDG_CONFIG_HOME}" "${XDG_DATA_HOME}"

launch_cmd='export HOME=/config HERMES_HOME=/config/.hermes XDG_CACHE_HOME=/config/.cache XDG_CONFIG_HOME=/config/.config XDG_DATA_HOME=/config/.local/share NPM_CONFIG_CACHE=/config/.cache/npm UV_CACHE_DIR=/config/.cache/uv; /usr/local/bin/hermes-apply-runtime-config >/tmp/hermes-runtime-config.log 2>&1 || true; cd /config; exec hermes'

if command -v konsole >/dev/null 2>&1; then
    exec konsole --workdir /config --hold -e /bin/bash -lc "${launch_cmd}"
fi

if command -v x-terminal-emulator >/dev/null 2>&1; then
    exec x-terminal-emulator -e /bin/bash -lc "${launch_cmd}; exec /bin/bash"
fi

if command -v xterm >/dev/null 2>&1; then
    exec xterm -hold -e /bin/bash -lc "${launch_cmd}"
fi

exec /bin/bash -lc "${launch_cmd}"
